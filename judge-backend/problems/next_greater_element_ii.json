{
    "id": "next_greater_element_ii",
    "title": "Next Greater Element II",
    "description": "Find next greater element in circular array.",
    "input_format": "Space-separated integers.",
    "output_format": "List of integers.",
    "constraints": {
        "n": "1-10^4"
    },
    "difficulty": "medium",
    "judge_mode": "str_compare_strip",
    "time_limit": 1,
    "sample_test_cases": [
        {
            "input": "1 2 1",
            "output": "2 -1 2"
        }
    ],
    "hidden_test_cases": [
        {
            "input": "1 2 3 4 3",
            "output": "2 3 4 -1 4"
        },
        {
            "input": "5 4 3 2 1",
            "output": "-1 5 5 5 5"
        },
        {
            "input": "1 1 1 1 1",
            "output": "-1 -1 -1 -1 -1"
        },
        {
            "input": "1",
            "output": "-1"
        },
        {
            "input": "10 1 10 1",
            "output": "-1 10 -1 10"
        },
        {
            "input": "1 5 2 4 3",
            "output": "5 -1 4 5 5"
        },
        {
            "input": "1 2 3 2 1",
            "output": "2 3 -1 3 2"
        },
        {
            "input": "100 1 11",
            "output": "-1 11 100"
        },
        {
            "input": "1 2 1 2 1",
            "output": "2 -1 2 -1 2"
        },
        {
            "input": "3 8 4 1 2",
            "output": "8 -1 8 2 3"
        }
    ]
}