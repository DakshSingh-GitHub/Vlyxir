{
    "id": "add_two_numbers",
    "title": "Add Two Numbers",
    "description": "Add two numbers represented by linked lists (digits in reverse order).",
    "input_format": "Two lists of integers separated by a newline.",
    "output_format": "A list of integers.",
    "constraints": {
        "nodes": "1-100",
        "val": "0-9"
    },
    "difficulty": "medium",
    "judge_mode": "str_compare_strip",
    "time_limit": 1,
    "sample_test_cases": [
        {
            "input": "2 4 3\n5 6 4",
            "output": "7 0 8"
        }
    ],
    "hidden_test_cases": [
        {
            "input": "0\n0",
            "output": "0"
        },
        {
            "input": "9 9 9\n1",
            "output": "0 0 0 1"
        },
        {
            "input": "1\n9 9 9",
            "output": "0 0 0 1"
        },
        {
            "input": "2 4\n5 6",
            "output": "7 0 1"
        },
        {
            "input": "5\n5",
            "output": "0 1"
        },
        {
            "input": "1 8\n0",
            "output": "1 8"
        },
        {
            "input": "9 9\n9",
            "output": "8 0 1"
        },
        {
            "input": "1 2 3\n4 5 6",
            "output": "5 7 9"
        },
        {
            "input": "9 9 9 9 9 9 9\n9 9 9 9",
            "output": "8 9 9 9 0 0 0 1"
        },
        {
            "input": "1\n0",
            "output": "1"
        }
    ]
}