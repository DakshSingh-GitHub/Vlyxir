{
    "id": "sort_list",
    "title": "Sort List",
    "description": "Sort a linked list in ascending order.",
    "input_format": "A list of integers.",
    "output_format": "A list of integers.",
    "constraints": {
        "nodes": "0 to 5 * 10^4"
    },
    "difficulty": "medium",
    "judge_mode": "str_compare_strip",
    "time_limit": 2,
    "sample_test_cases": [
        {
            "input": "4 2 1 3",
            "output": "1 2 3 4"
        }
    ],
    "hidden_test_cases": [
        {
            "input": "-1 5 3 4 0",
            "output": "-1 0 3 4 5"
        },
        {
            "input": "",
            "output": ""
        },
        {
            "input": "1",
            "output": "1"
        },
        {
            "input": "2 1",
            "output": "1 2"
        },
        {
            "input": "5 4 3 2 1",
            "output": "1 2 3 4 5"
        },
        {
            "input": "1 2 3 4 5",
            "output": "1 2 3 4 5"
        },
        {
            "input": "10 5 15 2",
            "output": "2 5 10 15"
        },
        {
            "input": "1 1 1 1",
            "output": "1 1 1 1"
        },
        {
            "input": "3 3 2 1",
            "output": "1 2 3 3"
        },
        {
            "input": "100 -100 0",
            "output": "-100 0 100"
        }
    ]
}