{
    "id": "first_bad_version",
    "title": "First Bad Version",
    "description": "Find first bad version using binary search.",
    "input_format": "n and bad.",
    "output_format": "Integer.",
    "constraints": {
        "n": "1 to 2^31 - 1"
    },
    "difficulty": "easy",
    "judge_mode": "str_compare_strip",
    "time_limit": 1,
    "sample_test_cases": [
        {
            "input": "5\n4",
            "output": "4"
        }
    ],
    "hidden_test_cases": [
        {
            "input": "1\n1",
            "output": "1"
        },
        {
            "input": "2\n1",
            "output": "1"
        },
        {
            "input": "2\n2",
            "output": "2"
        },
        {
            "input": "10\n1",
            "output": "1"
        },
        {
            "input": "10\n10",
            "output": "10"
        },
        {
            "input": "100\n50",
            "output": "50"
        },
        {
            "input": "100\n1",
            "output": "1"
        },
        {
            "input": "100\n100",
            "output": "100"
        },
        {
            "input": "2147483647\n2147483647",
            "output": "2147483647"
        },
        {
            "input": "2147483647\n1",
            "output": "1"
        }
    ]
}