{
    "id": "clone_graph",
    "title": "Clone Graph",
    "description": "Deep copy a connected undirected graph.",
    "input_format": "Adjacency list.",
    "output_format": "Adjacency list.",
    "constraints": {
        "nodes": "0-100"
    },
    "difficulty": "medium",
    "judge_mode": "str_compare_strip",
    "time_limit": 1,
    "sample_test_cases": [
        {
            "input": "[[2,4],[1,3],[2,4],[1,3]]",
            "output": "[[2,4],[1,3],[2,4],[1,3]]"
        }
    ],
    "hidden_test_cases": [
        {
            "input": "[[]]",
            "output": "[[]]"
        },
        {
            "input": "[]",
            "output": "[]"
        },
        {
            "input": "[[2],[1]]",
            "output": "[[2],[1]]"
        },
        {
            "input": "[[2,3],[1,3],[1,2]]",
            "output": "[[2,3],[1,3],[1,2]]"
        },
        {
            "input": "[[2],[1,3],[2]]",
            "output": "[[2],[1,3],[2]]"
        },
        {
            "input": "[[2,4],[1,3],[2,4],[1,3]]",
            "output": "[[2,4],[1,3],[2,4],[1,3]]"
        },
        {
            "input": "[[2,3,4],[1,3,4],[1,2,4],[1,2,3]]",
            "output": "[[2,3,4],[1,3,4],[1,2,4],[1,2,3]]"
        },
        {
            "input": "[[2],[1]]",
            "output": "[[2],[1]]"
        },
        {
            "input": "[[]]",
            "output": "[[]]"
        },
        {
            "input": "[[2,3,4,5],[1],[1],[1],[1]]",
            "output": "[[2,3,4,5],[1],[1],[1],[1]]"
        }
    ]
}