    "time_limit": 2,
    "sample_test_cases": [
        {
            "input": "1 2 3",
            "output": "6"
        }
    ],
    "hidden_test_cases": [
        {
            "input": "-10 9 20 null null 15 7",
            "output": "42"
        },
        {
            "input": "0",
            "output": "0"
        },
        {
            "input": "1",
            "output": "1"
        },
        {
            "input": "-3",
            "output": "-3"
        },
        {
            "input": "2 -1",
            "output": "2"
        },
        {
            "input": "-2 1",
            "output": "1"
        },
        {
            "input": "1 2 null 3 null 4",
            "output": "10"
        },
        {
            "input": "2 -1 -2",
            "output": "2"
        },
        {
            "input": "5 4 8 11 null 13 4 7 2 null null null 1",
            "output": "48"
        },
        {
            "input": "1 2 3 4 5 6 7",
            "output": "18"
        }
    ]
}