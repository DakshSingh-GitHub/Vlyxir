{
    "id": "binary_tree_maximum_path_sum",
    "title": "Binary Tree Maximum Path Sum",
    "description": "Return maximum path sum in a binary tree.",
    "input_format": "Level-order representation.",
    "output_format": "An integer.",
    "constraints": {
