{
    "id": "course_schedule_ii",
    "title": "Course Schedule II",
    "description": "Return topological sort of courses.",
    "input_format": "numCourses and prerequisites array.",
    "output_format": "Course ordering array.",
    "constraints": {
        "numCourses": "1-2000"
    },
    "difficulty": "medium",
    "judge_mode": "str_compare_strip",
    "time_limit": 1,
    "sample_test_cases": [
        {
            "input": "2\n[[1,0]]",
            "output": "[0,1]"
        }
    ],
    "hidden_test_cases": [
        {
            "input": "1\n[]",
            "output": "[0]"
        },
        {
            "input": "2\n[]",
            "output": "[0,1]"
        },
        {
            "input": "2\n[[0,1],[1,0]]",
            "output": "[]"
        },
        {
            "input": "4\n[[1,0],[2,0],[3,1],[3,2]]",
            "output": "[0,1,2,3]"
        },
        {
            "input": "3\n[[1,0],[2,1]]",
            "output": "[0,1,2]"
        },
        {
            "input": "3\n[[1,0],[0,1]]",
            "output": "[]"
        },
        {
            "input": "3\n[[1,0],[2,0]]",
            "output": "[0,1,2]"
        },
        {
            "input": "5\n[[1,0],[2,0],[3,1],[4,2]]",
            "output": "[0,1,2,3,4]"
        },
        {
            "input": "2\n[[0,1]]",
            "output": "[1,0]"
        },
        {
            "input": "4\n[[1,0],[2,0],[3,1],[3,2]]",
            "output": "[0,2,1,3]"
        }
    ]
}