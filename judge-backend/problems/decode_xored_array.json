{
    "id": "decode_xored_array",
    "title": "Decode XORed Array",
    "description": "There is a hidden integer array arr that consists of n non-negative integers. It was encoded into another integer array encoded of length n - 1, such that encoded[i] = arr[i] XOR arr[i + 1]. For example, if arr = [1,0,2,1], then encoded = [1,2,3].\n\nYou are given the encoded array and an integer first, which is the first element of arr, i.e. arr[0]. Return the original array arr.",
    "input_format": "First line encoded array (space-separated). Second line integer first.",
    "output_format": "Space-separated original array.",
    "constraints": {
        "n": "2 <= n <= 10^4"
    },
    "difficulty": "easy",
    "judge_mode": "str_compare_strip",
