{
    "id": "copy_list_with_random_pointer",
    "title": "Copy List with Random Pointer",
    "description": "Construct a deep copy of a linked list with random pointers.",
    "input_format": "A 2D array representation [[val, random_index], ...].",
    "output_format": "A 2D array representation.",
    "constraints": {
        "n": "0-1000"
    },
    "difficulty": "medium",
    "judge_mode": "str_compare_strip",
    "time_limit": 1,
    "sample_test_cases": [
        {
            "input": "[[7,null],[13,0],[11,4],[10,2],[1,0]]",
            "output": "[[7,null],[13,0],[11,4],[10,2],[1,0]]"
        }
    ],
    "hidden_test_cases": [
        {
            "input": "[[1,1],[2,1]]",
            "output": "[[1,1],[2,1]]"
        },
        {
            "input": "[[3,null],[3,0],[3,null]]",
            "output": "[[3,null],[3,0],[3,null]]"
        },
        {
            "input": "[]",
            "output": "[]"
        },
        {
            "input": "[[1,0]]",
            "output": "[[1,0]]"
        },
        {
            "input": "[[1,null]]",
            "output": "[[1,null]]"
        },
        {
            "input": "[[1,null],[2,0]]",
            "output": "[[1,null],[2,0]]"
        },
        {
            "input": "[[1,1],[2,0]]",
            "output": "[[1,1],[2,0]]"
        },
        {
            "input": "[[1,2],[2,null],[3,0]]",
            "output": "[[1,2],[2,null],[3,0]]"
        },
        {
            "input": "[[1,1],[1,1],[1,1]]",
            "output": "[[1,1],[1,1],[1,1]]"
        },
        {
            "input": "[[10,null],[20,0],[30,1]]",
            "output": "[[10,null],[20,0],[30,1]]"
        }
    ]
}